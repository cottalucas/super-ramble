rules_version = '2';

// Every document is scoped to its owner. No cross-user reads or writes.
// Personal free text is encrypted client-side before it ever reaches here,
// so even an owner read returns ciphertext. See docs/architecture.md.
service cloud.firestore {
  match /databases/{database}/documents {

    // A user owns everything under their own uid.
    match /users/{uid}/{document=**} {
      allow read, write: if request.auth != null && request.auth.uid == uid;
    }

    // Usage records are written by the Function (Admin SDK bypasses rules).
    // Clients may read their own usage but never write it.
    match /users/{uid}/llmUsage/{day} {
      allow read: if request.auth != null && request.auth.uid == uid;
      allow write: if false;
    }

    // Deny everything else by default.
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
