rules_version = '2';

// Every document is scoped to its owner. No cross-user reads or writes.
// Usage records are written by the Function (Admin SDK bypasses rules); clients
// may read their own but never write them. See docs/architecture.md.
service cloud.firestore {
  match /databases/{database}/documents {

    function isOwner(uid) {
      return request.auth != null && request.auth.uid == uid;
    }

    match /users/{uid} {
      // Profile and settings on the user document itself.
      allow read, write: if isOwner(uid);

      match /projects/{projectId} {
        allow read, write: if isOwner(uid);
      }
      match /sections/{sectionId} {
        allow read, write: if isOwner(uid);
      }
      match /tasks/{taskId} {
        allow read, write: if isOwner(uid);
      }
      match /labels/{labelId} {
        allow read, write: if isOwner(uid);
      }
      match /comments/{commentId} {
        allow read, write: if isOwner(uid);
      }
      match /drafts/{draftId} {
        allow read, write: if isOwner(uid);
      }
      // Usage is read-only to the client; only the Function writes it.
      match /llmUsage/{day} {
        allow read: if isOwner(uid);
        allow write: if false;
      }
      // Structuring traces (transcript, response, confirm/cancel outcome).
      // The owner can now read their own trace document: the async-Structure
      // pass (docs/resolution-log.md) has the client subscribe to its own
      // trace via onSnapshot (SuperRambleModal.jsx) to learn when
      // processStructureTrace (functions/index.js) finishes the real work, so
      // this can no longer stay fully denied the way it did while every real
      // call was synchronous end to end. Write stays denied to every client,
      // owner included: only the Function (Admin SDK, both the enqueue write
      // and the processing trigger) and the local review/promote scripts
      // (also Admin SDK, which bypasses rules regardless of what they say)
      // ever write here.
      match /structureTraces/{traceId} {
        allow read: if isOwner(uid);
        allow write: if false;
      }
      // The Todoist OAuth token (access + refresh), never readable by the
      // client, not even the owner: unlike encrypted personal task text,
      // this Function has to read it in plaintext to call Todoist on the
      // user's behalf, so client-side encryption isn't an option here. Same
      // rule shape as structureTraces above, but a distinct case for a
      // distinct reason. Only the Function (Admin SDK) ever touches this
      // collection; Admin SDK bypasses rules regardless of what they say,
      // so this line states intent, it is not their gate. See
      // docs/architecture.md.
      match /todoistAuth/{docId} {
        allow read, write: if false;
      }
    }

    // The live reference-examples pool and the pipeline-learnings log are
    // both global, not scoped under a single users/{uid}: a reference
    // example teaches the live model for every future call regardless of
    // whose transcript prompted it, so it lives at the top level like these
    // two, not nested per-user. Never read or written by the client SDK: only
    // the Function (the /api/structure handler that reads referenceExamples,
    // and the structureTraces trigger that grades and may write to both),
    // and local scripts (seed-reference-examples.mjs, review-queue.mjs,
    // sync-learnings.mjs, also Admin SDK) touch either collection. Admin SDK
    // bypasses rules regardless of what they say, so these lines state
    // intent, the same as structureTraces/todoistAuth above; they are not
    // the real gate.
    match /referenceExamples/{exampleId} {
      allow read, write: if false;
    }
    match /pipelineLearningLog/{logId} {
      allow read, write: if false;
    }

    // Deny everything else by default.
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
