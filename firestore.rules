rules_version = '2';

// Every document is scoped to its owner. No cross-user reads or writes.
// Usage records are written by the Function (Admin SDK bypasses rules); clients
// may read their own but never write them. See docs/architecture.md.
service cloud.firestore {
  match /databases/{database}/documents {

    function isOwner(uid) {
      return request.auth != null && request.auth.uid == uid;
    }

    match /users/{uid} {
      // Profile and settings on the user document itself.
      allow read, write: if isOwner(uid);

      match /projects/{projectId} {
        allow read, write: if isOwner(uid);
      }
      match /sections/{sectionId} {
        allow read, write: if isOwner(uid);
      }
      match /tasks/{taskId} {
        allow read, write: if isOwner(uid);
      }
      match /labels/{labelId} {
        allow read, write: if isOwner(uid);
      }
      match /drafts/{draftId} {
        allow read, write: if isOwner(uid);
      }
      // Usage is read-only to the client; only the Function writes it.
      match /llmUsage/{day} {
        allow read: if isOwner(uid);
        allow write: if false;
      }
    }

    // Deny everything else by default.
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
