# Copy to .env.local and fill with real values. Never commit .env.local.
# These are the web client config for the super-ramble Firebase project.
# All VITE_* values are public by design (they ship to the browser).
# No secret keys belong here. The Anthropic key and Todoist client secret
# are Firebase Functions secrets, never web env.

VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=super-ramble.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=super-ramble
VITE_FIREBASE_STORAGE_BUCKET=super-ramble.firebasestorage.app
VITE_FIREBASE_MESSAGING_SENDER_ID=109208111357
VITE_FIREBASE_APP_ID=1:109208111357:web:32c9b7f9b8a2f17a4fd694
VITE_FIREBASE_MEASUREMENT_ID=G-K3EL5D5FE4

# The Todoist app's own OAuth client id, public by design, not a secret.
# TODOIST_CLIENT_SECRET (the real secret) is a Firebase Functions secret, set
# with firebase functions:secrets:set, never here.
VITE_TODOIST_CLIENT_ID=

# Local-only flags (set in .env.local, not in production).
# Show the placeholder page without signing in.
VITE_ENABLE_LOCAL_PREVIEW=true
# Enable the Vite dev bridge for live structuring tests. The Anthropic key
# stays server-side; the browser still never sees it.
VITE_ENABLE_LIVE_LLM=false
