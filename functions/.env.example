# Copy to functions/.env for local emulation. Never commit functions/.env.
# Secrets (ANTHROPIC_API_KEY, TODOIST_CLIENT_SECRET) are NOT set here. They are
# Firebase Functions secrets:
#   firebase functions:secrets:set ANTHROPIC_API_KEY
#   firebase functions:secrets:set TODOIST_CLIENT_SECRET

# Pinned model, Haiku by default for every call.
ANTHROPIC_MODEL=claude-haiku-4-5-20251001

# Deliberate, named exception: the structuring call runs on Sonnet, not
# Haiku, for structuring quality. See docs/resolution-log.md.
ANTHROPIC_STRUCTURE_MODEL=claude-sonnet-5

# Per-user daily limits enforced by the Function. Sized for Sonnet's ~3x
# per-token cost on the structuring call; see docs/resolution-log.md.
LLM_DAILY_REQUEST_LIMIT=100
LLM_DAILY_COST_LIMIT_USD=4

# Raw prompts/responses are off by default. Local debugging tool only.
LLM_STORE_RAW_TRACES=false

# Todoist OAuth (public client id is fine here; the secret is a Function secret).
TODOIST_CLIENT_ID=
TODOIST_OAUTH_SCOPE=data:read_write
